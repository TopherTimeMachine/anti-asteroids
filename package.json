{
  "name": "anti-Asteroids",
  "version": "1.0.3",
  "description": "Multiplayer retro 8-bit Asteroids game using WebSockets and TypeScript",
  "main": "dist/server/server.js",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/server.ts",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "tsc -p tsconfig.client.json && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/server.js"
  },
  "keywords": [
    "asteroids",
    "multiplayer",
    "websockets",
    "typescript",
    "canvas",
    "retro",
    "8bit"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
